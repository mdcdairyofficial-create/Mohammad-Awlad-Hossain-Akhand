rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'super_admin'); 
    }

    match /users/{userId} {
      allow list: if isSignedIn() || request.auth == null || isAdmin();
      allow read: if isSignedIn() || request.auth == null || isAdmin();
      allow create: if isSignedIn() || request.auth == null;
      allow update: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /cases/{caseId} {
      allow list, read: if isSignedIn() || request.auth == null || isAdmin();
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /notifications/{notificationId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /global_notifications/{notificationId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /tasks/{taskId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }
    
    match /recharge_orders/{orderId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /recharge_history/{historyId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /online_payments/{paymentId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /memories/{memoryId} {
      allow list, read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /templates/{templateId} {
      allow list, read: if true;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if request.auth == null || isAdmin();
    }

    match /legalDrafts/{draftId} {
      allow list, read: if true;
      allow create: if isSignedIn() || request.auth == null;
      allow update: if isSignedIn() || request.auth == null;
      allow delete: if request.auth == null || isAdmin();
    }

    match /library_books/{bookId} {
      allow list, read: if true;
      allow create, update, delete: if request.auth == null || isAdmin();
    }

    match /news/{newsId} {
      allow list, read: if true;
      allow create, update, delete: if isSignedIn() || request.auth == null;
    }

    match /complaints/{complaintId} {
      allow list, read: if true;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null;
    }

    match /audit_logs/{logId} {
      allow list, read: if true;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null;
    }

    match /appeals/{appealId} {
      allow list, read: if true;
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null;
    }

    match /user_media/{mediaId} {
      allow list, read: if true;
      allow create, update: if isSignedIn() || request.auth == null;
      allow delete: if request.auth == null || isAdmin();
    }

    match /lotteryWinners/{winnerId} {
      allow list, read: if true;
      allow create, update: if isSignedIn() || request.auth == null;
      allow delete: if request.auth == null || isAdmin();
    }

    match /advertisements/{adId} {
      allow list, read: if true;
      allow create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /campaigns/{campaignId} {
      allow list, read, create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /subscription_requests/{requestId} {
      allow list, read: if isSignedIn() || request.auth == null || isAdmin();
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /affiliate_proofs/{proofId} {
      allow list, read: if isSignedIn() || request.auth == null || isAdmin();
      allow create: if isSignedIn() || request.auth == null;
      allow update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /chat_sessions/{sessionId} {
      allow list, read, create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
      
      match /messages/{messageId} {
        allow list, read, create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
      }
    }

    match /archive_cases/{caseId} {
      allow list, read, create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }

    match /points_history/{historyId} {
      allow list, read, create, update, delete: if isSignedIn() || request.auth == null || isAdmin();
    }
  }
}
