rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'super_admin'); 
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if (isSignedIn() && isOwner(userId)) || isAdmin() || request.auth == null;
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && isOwner(userId)) || isAdmin();
    }

    match /cases/{caseId} {
      allow list: if isSignedIn() || request.auth == null;
      allow read: if (isSignedIn() && (resource.data.user_id == request.auth.uid || resource.data.visibility == 'public')) || isAdmin() || request.auth == null;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if (isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin()));
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() || request.auth == null;
      allow read, delete: if (isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin())) || request.auth == null;
      allow create: if isSignedIn();
    }

    match /global_notifications/{notificationId} {
      allow list: if isSignedIn();
      allow read: if isSignedIn() || request.auth == null;
      allow create, update, delete: if isAdmin() || request.auth == null;
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow read, update, delete: if (isSignedIn() && (resource.data.assignedTo == request.auth.uid || isAdmin())) || request.auth == null;
      allow create: if isSignedIn();
    }
    
    match /recharge_orders/{orderId} {
      allow list: if isSignedIn();
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /recharge_history/{historyId} {
      allow list: if isSignedIn();
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn();
    }

    match /online_payments/{paymentId} {
      allow list: if isAdmin();
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
    }

    match /memories/{memoryId} {
      allow list: if isSignedIn() || request.auth == null;
      allow read, update, delete: if (isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin())) || request.auth == null;
      allow create: if (isSignedIn() && request.resource.data.user_id == request.auth.uid) || request.auth == null;
    }

    match /templates/{templateId} {
      allow list, read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /library_books/{bookId} {
      allow list, read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /advertisements/{adId} {
      allow list, read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow list: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /subscription_requests/{requestId} {
      allow list: if isAdmin();
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
    }

    match /affiliate_proofs/{proofId} {
      allow list: if isAdmin();
      allow read: if (isSignedIn() && resource.data.user_id == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAdmin();
    }

    match /chat_sessions/{sessionId} {
      allow list: if isSignedIn();
      allow read, update: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      
      match /messages/{messageId} {
        allow list, read: if isSignedIn() && (get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.user_id == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && (get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.user_id == request.auth.uid || isAdmin());
      }
    }

    match /archive_cases/{caseId} {
      allow list, read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
