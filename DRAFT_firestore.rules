rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isUserAuthenticated(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isUserAuthenticated(userId) || isAdmin();
      allow create: if isUserAuthenticated(userId) && incoming().firebase_uid == request.auth.uid;
      allow update: if isUserAuthenticated(userId) && incoming().firebase_uid == existing().firebase_uid;
    }

    // --- Cases Collection ---
    match /cases/{caseId} {
      allow read: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid;
      allow update: if isSignedIn() && existing().user_id == request.auth.uid;
    }

    // --- Other collections will be hardened similarly ---
  }
}
